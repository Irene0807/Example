{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$j = [System.Console]::In.ReadToEnd() | ConvertFrom-Json; $fp = $j.tool_input.file_path; if ($fp -and $fp -match 'lookup_example' -and $fp -match 'scripts' -and $fp.EndsWith('.py')) { & \"$env:LOCALAPPDATA\\Microsoft\\WindowsApps\\python.exe\" -m py_compile $fp 2>$null }",
            "statusMessage": "驗證 Python 語法...",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
